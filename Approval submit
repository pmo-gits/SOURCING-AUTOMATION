function processApprovals() {

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const ui = SpreadsheetApp.getUi();
  const activeSheet = ss.getActiveSheet();
  const activeSheetName = activeSheet.getName();

  // 🔒 RUN ONLY FROM USER APPROVAL SHEETS
  if (!activeSheetName.endsWith("-APPROVAL SHEET")) {
    ui.alert("Please run this from an APPROVAL SHEET only.");
    return;
  }

  // 🔒 EMAIL AUTHORIZATION CHECK FROM AA1
  const allowedEmail = String(activeSheet.getRange("AA1").getDisplayValue()).trim().toLowerCase();
  const approverEmail = String(Session.getActiveUser().getEmail()).trim().toLowerCase();

  if (!allowedEmail) {
    ui.alert("Authorized email is missing in AA1.");
    return;
  }

  if (approverEmail !== allowedEmail) {
    ui.alert("You are not authorized to approve from this sheet.");
    return;
  }

  // 🔒 PREVENT PARALLEL APPROVAL RUNS
  const lock = LockService.getDocumentLock();

  if (!lock.tryLock(0)) {
    ui.alert("Another approval process is running. Please try again.");
    return;
  }

  try {

    const approvalSheet = activeSheet;
    const summarySheet = ss.getSheetByName("SUBMIT SUMMARY SHEET");

    // Column numbers in Approval Sheet
    const JOIN_KEY_COL = 20;      // T
    const SOURCE_KEY_COL = 21;    // U
    const STATUS_COL = 22;        // V
    const COMMENT_COL = 23;       // W

    const lastRowApproval = approvalSheet.getLastRow();

    if (lastRowApproval < 2) {
      ui.alert("No approval data found.");
      return;
    }

    // --- Read Approval Sheet data ---
    const approvalData = approvalSheet.getRange(2, JOIN_KEY_COL, lastRowApproval - 1, 4).getValues(); // T,U,V,W

    // Prepare maps for validation
    const joinKeys = approvalData.map(r => r[0]);
    const statusValues = approvalData.map(r => r[2]);

    // Map JOIN_KEY -> indices
    const keyMap = {};
    for (let i = 0; i < joinKeys.length; i++) {
      const key = joinKeys[i];
      if (!key) continue;
      if (!keyMap[key]) keyMap[key] = [];
      keyMap[key].push(i);
    }

    // --- Validation for duplicate JOIN_KEYs ---
    for (const key in keyMap) {
      const indices = keyMap[key];
      if (indices.length < 2) continue;

      const values = indices.map(i => statusValues[i]);
      const allBlank = values.every(v => !v);
      const allFilled = values.every(v => v);

      if (!allBlank && !allFilled) {
        ui.alert("Fill the APPROVAL COMMENTS for all the quotation values");
        return;
      }
    }

    const approvalTimestamp = new Date();

    // --- Prepare rows to append ---
    const rowsToAppend = [];
    const rowsToClear = [];

    for (let i = 0; i < approvalData.length; i++) {
      const joinKey = approvalData[i][0];
      const sourceKey = approvalData[i][1];
      const status = approvalData[i][2];
      const comment = approvalData[i][3];

      if (!joinKey) continue;
      if (!status) continue;

      rowsToAppend.push([
        joinKey,
        sourceKey,
        status,
        comment,
        approverEmail,
        approvalTimestamp
      ]);

      rowsToClear.push(i + 2);
    }

    // --- Append to SUBMIT SUMMARY SHEET ---
    if (rowsToAppend.length > 0) {
      let firstEmptyRow = summarySheet.getRange("A:A").getValues().filter(String).length + 1;
      summarySheet.getRange(firstEmptyRow, 1, rowsToAppend.length, 6).setValues(rowsToAppend);
    }

    // --- Clear V & W in Approval Sheet for appended rows ---
    for (const row of rowsToClear) {
      approvalSheet.getRange(row, STATUS_COL).clearContent();
      approvalSheet.getRange(row, COMMENT_COL).clearContent();
    }

    ui.alert("Approval submitted successfully.");

  } finally {
    lock.releaseLock();
  }
}
