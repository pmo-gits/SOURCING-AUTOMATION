function onFormSubmit(e) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const FORM_SHEET_NAME = "Form Responses 1";
  const REQUEST_SHEET_NAME = "REQUEST LIST";

  const SOURCING_HEADER = "SOURCING REQUEST NO";
  const EMAIL_HEADER = "Email Address";
  const CATEGORY_HEADER = "CATEGORY";
  const COMMENT_HEADER = "ON HOLD / CANCELLED COMMENT - UPDATION";

  const CUSTOMER_HEADER = "CUSTOMER NAME";
  const MATERIAL_DESC_HEADER = "MATERIAL DESCRIPTION";
  const COLOR_HEADER = "COLOR FINISH";
  const MATERIAL_CONTENT_HEADER = "MATERIAL CONTENT/FABRIC TYPE";
  const QTY_HEADER = "QTY REQUIRED";

  const RIZWAN_EMAIL = "pmo@butlerleather.com";

  const formSheet = ss.getSheetByName(FORM_SHEET_NAME);
  const requestSheet = ss.getSheetByName(REQUEST_SHEET_NAME);

  if (!formSheet || !requestSheet) {
    throw new Error("Required sheet not found.");
  }

  const submittedRow = e.range.getRow();
  const formHeaders = formSheet
    .getRange(1, 1, 1, formSheet.getLastColumn())
    .getDisplayValues()[0]
    .map(h => String(h).trim());

  const sourcingColForm = formHeaders.indexOf(SOURCING_HEADER) + 1;
  const emailColForm = formHeaders.indexOf(EMAIL_HEADER) + 1;
  const categoryColForm = formHeaders.indexOf(CATEGORY_HEADER) + 1;

  const submitterNameColForm =
    formHeaders.indexOf("SUBMITTER NAME") + 1 ||
    formHeaders.indexOf("SUBMITTED BY") + 1 ||
    formHeaders.indexOf("RAISED BY") + 1 ||
    formHeaders.indexOf("NAME") + 1;

  if (sourcingColForm === 0) {
    throw new Error("SOURCING REQUEST NO header not found in Form Responses 1.");
  }

  if (emailColForm === 0) {
    throw new Error("Email Address header not found in Form Responses 1.");
  }

  if (categoryColForm === 0) {
    throw new Error("CATEGORY header not found in Form Responses 1.");
  }

  const sourcingId = String(
    formSheet.getRange(submittedRow, sourcingColForm).getDisplayValue()
  ).trim();

  const submitterEmail = String(
    formSheet.getRange(submittedRow, emailColForm).getDisplayValue()
  ).trim().toLowerCase();

  const submitterName = submitterNameColForm
    ? String(formSheet.getRange(submittedRow, submitterNameColForm).getDisplayValue()).trim()
    : submitterEmail;

  const category = String(
    formSheet.getRange(submittedRow, categoryColForm).getDisplayValue()
  ).trim().toUpperCase();

  if (!sourcingId || !submitterEmail) {
    return;
  }

  const requestHeaders = requestSheet
    .getRange(1, 1, 1, requestSheet.getLastColumn())
    .getDisplayValues()[0]
    .map(h => String(h).trim());

  const sourcingColRequest = requestHeaders.indexOf(SOURCING_HEADER) + 1;
  const commentColRequest = requestHeaders.indexOf(COMMENT_HEADER) + 1;

  const customerColRequest = requestHeaders.indexOf(CUSTOMER_HEADER) + 1;
  const materialDescColRequest = requestHeaders.indexOf(MATERIAL_DESC_HEADER) + 1;
  const colorColRequest = requestHeaders.indexOf(COLOR_HEADER) + 1;
  const materialContentColRequest = requestHeaders.indexOf(MATERIAL_CONTENT_HEADER) + 1;
  const qtyColRequest = requestHeaders.indexOf(QTY_HEADER) + 1;

  const ref1ColRequest = requestHeaders.indexOf("REFERENCE IMAGE 1") + 1;
  const ref2ColRequest = requestHeaders.indexOf("REFERENCE IMAGE 2") + 1;
  const ref3ColRequest = requestHeaders.indexOf("REFERENCE IMAGE 3") + 1;
  const ref4ColRequest = requestHeaders.indexOf("REFERENCE IMAGE 4") + 1;
  const ref5ColRequest = requestHeaders.indexOf("REFERENCE IMAGE 5") + 1;

  if (sourcingColRequest === 0) {
    throw new Error("SOURCING REQUEST NO header not found in REQUEST LIST.");
  }

  if (commentColRequest === 0) {
    throw new Error("ON HOLD / CANCELLED COMMENT - UPDATION header not found in REQUEST LIST.");
  }

  if (category === "LEATHER") {
    const missingHeaders = [];

    if (customerColRequest === 0) missingHeaders.push(CUSTOMER_HEADER);
    if (materialDescColRequest === 0) missingHeaders.push(MATERIAL_DESC_HEADER);
    if (colorColRequest === 0) missingHeaders.push(COLOR_HEADER);
    if (materialContentColRequest === 0) missingHeaders.push(MATERIAL_CONTENT_HEADER);
    if (qtyColRequest === 0) missingHeaders.push(QTY_HEADER);
    if (ref1ColRequest === 0) missingHeaders.push("REFERENCE IMAGE 1");
    if (ref2ColRequest === 0) missingHeaders.push("REFERENCE IMAGE 2");
    if (ref3ColRequest === 0) missingHeaders.push("REFERENCE IMAGE 3");
    if (ref4ColRequest === 0) missingHeaders.push("REFERENCE IMAGE 4");
    if (ref5ColRequest === 0) missingHeaders.push("REFERENCE IMAGE 5");

    if (missingHeaders.length > 0) {
      throw new Error("Missing REQUEST LIST header(s): " + missingHeaders.join(", "));
    }
  }

  const lastRow = requestSheet.getLastRow();
  if (lastRow < 2) return;

  const sourcingValues = requestSheet
    .getRange(2, sourcingColRequest, lastRow - 1, 1)
    .getDisplayValues();

  let matchedRow = null;

  for (let i = 0; i < sourcingValues.length; i++) {
    const requestSourcingId = String(sourcingValues[i][0]).trim();

    if (requestSourcingId === sourcingId) {
      matchedRow = i + 2;
      break;
    }
  }

  if (!matchedRow) return;

  const targetCell = requestSheet.getRange(matchedRow, commentColRequest);

  const protections = requestSheet.getProtections(SpreadsheetApp.ProtectionType.RANGE);

  protections.forEach(protection => {
    const protectedRange = protection.getRange();

    if (
      protectedRange.getRow() === targetCell.getRow() &&
      protectedRange.getColumn() === targetCell.getColumn() &&
      protectedRange.getNumRows() === 1 &&
      protectedRange.getNumColumns() === 1
    ) {
      protection.remove();
    }
  });

  const protection = targetCell.protect();
  protection.setDescription("Protected comment updation cell for " + sourcingId);

  protection.removeEditors(protection.getEditors());
  protection.addEditor(submitterEmail);

  if (protection.canDomainEdit()) {
    protection.setDomainEdit(false);
  }

  if (category === "LEATHER") {
    const customerName = String(requestSheet.getRange(matchedRow, customerColRequest).getDisplayValue()).trim();
    const materialDescription = String(requestSheet.getRange(matchedRow, materialDescColRequest).getDisplayValue()).trim();
    const colorFinish = String(requestSheet.getRange(matchedRow, colorColRequest).getDisplayValue()).trim();
    const materialContent = String(requestSheet.getRange(matchedRow, materialContentColRequest).getDisplayValue()).trim();
    const qtyRequired = String(requestSheet.getRange(matchedRow, qtyColRequest).getDisplayValue()).trim();

    const ref1 = String(requestSheet.getRange(matchedRow, ref1ColRequest).getDisplayValue()).trim();
    const ref2 = String(requestSheet.getRange(matchedRow, ref2ColRequest).getDisplayValue()).trim();
    const ref3 = String(requestSheet.getRange(matchedRow, ref3ColRequest).getDisplayValue()).trim();
    const ref4 = String(requestSheet.getRange(matchedRow, ref4ColRequest).getDisplayValue()).trim();
    const ref5 = String(requestSheet.getRange(matchedRow, ref5ColRequest).getDisplayValue()).trim();

    const subject = sourcingId + "- New sourcing request - " + customerName;

    const htmlBody =
      '<p>Dear Mr. Rizwan,</p>' +
      '<p>This is to inform you that a sourcing request has been raised by <b>' + submitterName + '</b>.</p>' +
      '<br>' +
      '<p><b>SOURCING REQUEST DETAILS:</b></p>' +
      '<p>' +
      '<b>SRC NO :</b>' + sourcingId + '<br>' +
      '<b>CUSTOMER NAME :</b>' + customerName + '<br>' +
      '<b>MATERIAL DESCRIPTION :</b>' + materialDescription + '<br>' +
      '<b>COLOR/FINISH :</b>' + colorFinish + '<br>' +
      '<b>MATERIAL CONTENT/FABRIC TYPE :</b>' + materialContent + '<br>' +
      '<b>QTY REQUIRED :</b>' + qtyRequired +
      '</p>' +
      '<br>' +
      '<p><b>REFERENCE IMAGES:</b></p>' +
      '<p>' +
      ref1 + '<br>' +
      ref2 + '<br>' +
      ref3 + '<br>' +
      ref4 + '<br>' +
      ref5 +
      '</p>' +
      '<br><br>' +
      '<p>For further details and necessary action, kindly review the sourcing sheet</p>';

    MailApp.sendEmail({
      to: RIZWAN_EMAIL,
      cc: submitterEmail,
      replyTo: submitterEmail,
      subject: subject,
      htmlBody: htmlBody
    });
  }
}
